{
    "name": "ajay/sylius-media-hub-plugin",
    "type": "sylius-plugin",
    "description": "Centralized Sylius admin dashboard for product and taxon images.",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "media",
        "catalog",
        "images"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "sylius/sylius": "^2.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/security-http": "^6.4 || ^7.0",
        "doctrine/orm": "^2.15 || ^3.0",
        "pagerfanta/core": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "symfony/browser-kit": "^6.4 || ^7.0",
        "symfony/css-selector": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Ajay\\SyliusMediaHubPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ajay\\SyliusMediaHubPlugin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        },
        "symfony": {
            "require": "^6.4 || ^7.0"
        }
    }
}
