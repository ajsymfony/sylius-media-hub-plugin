<div class="row row-cards">
    {% for item in items %}
        <div class="col-sm-6 col-xl-4">
            <div class="card h-100 overflow-hidden">
                <div class="position-relative bg-light" style="aspect-ratio: 4 / 3;">
                    <img
                        src="{{ asset('media/image/' ~ item.imagePath) }}"
                        alt="{{ item.name }}"
                        class="w-100 h-100 object-fit-cover"
                        loading="lazy"
                    >
                    <span class="badge bg-dark-lt position-absolute top-0 end-0 m-3">{{ item.kindLabel }}</span>
                </div>

                <div class="card-body d-flex flex-column gap-3">
                    <div>
                        <div class="fw-bold">{{ item.name }}</div>
                        <div class="text-secondary small">{{ item.identifier }}</div>
                    </div>

                    <dl class="row small mb-0">
                        <dt class="col-4 text-secondary">{{ 'ajay_sylius_media_hub.ui.filename'|trans }}</dt>
                        <dd class="col-8 text-break">{{ item.filename }}</dd>

                        <dt class="col-4 text-secondary">{{ 'ajay_sylius_media_hub.ui.last_update'|trans }}</dt>
                        <dd class="col-8">
                            {{ item.updatedAt ? item.updatedAt|date('Y-m-d H:i') : 'n/a' }}
                        </dd>
                    </dl>

                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" href="{{ path(item.editRoute, item.editRouteParameters) }}">
                            {{ item.product ? 'ajay_sylius_media_hub.ui.edit_product'|trans : 'ajay_sylius_media_hub.ui.edit_taxon'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
